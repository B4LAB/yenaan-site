---
import site from '../content/en/site.json';
import home from '../content/en/home.json';
const activeBrands = home.brands.filter((b) => b.status === 'active');
---
<footer id="contact" class="mt-0" style="background:var(--color-charcoal); color:#f1f2ee">
  <div class="mx-auto max-w-6xl px-6 lg:px-10 pt-20 pb-14">
    <!-- House seal -->
    <div class="text-center pb-16" style="border-bottom:1px solid rgba(241,242,238,0.12)">
      <p class="wordmark text-3xl md:text-4xl" style="letter-spacing:0.34em; color:var(--color-citron)">{site.brandName}</p>
      <p class="mt-4 text-[0.72rem] tracking-[0.28em] uppercase" style="color:rgba(241,242,238,0.45)">A Korean Skincare Brand House</p>
    </div>

    <div class="grid md:grid-cols-[1.3fr_1fr_1fr] gap-12 pt-14">
      <div>
        <p class="text-[0.72rem] tracking-[0.22em] uppercase font-semibold mb-4" style="color:rgba(241,242,238,0.5)">Contact</p>
        <a href={site.whatsapp.href} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-sm transition-opacity hover:opacity-70" style="color:rgba(241,242,238,0.75)">
          <svg viewBox="0 0 32 32" width="18" height="18" aria-hidden="true" fill="currentColor"><path d="M16 .6C7.5.6.6 7.5.6 16c0 2.8.7 5.4 2.1 7.8L.5 31.5l7.9-2.1c2.3 1.2 4.8 1.9 7.6 1.9h.1c8.5 0 15.4-6.9 15.4-15.4C31.5 7.5 24.6.6 16 .6zm0 28.2h-.1c-2.4 0-4.8-.7-6.9-1.9l-.5-.3-4.7 1.2 1.3-4.6-.3-.5C3.4 20.5 2.7 18.3 2.7 16 2.7 8.7 8.7 2.7 16 2.7c3.6 0 6.9 1.4 9.4 3.9 2.5 2.5 3.9 5.9 3.9 9.4 0 7.3-6 13.3-13.3 13.3zm7.3-9.9c-.4-.2-2.4-1.2-2.7-1.3-.4-.1-.6-.2-.9.2-.3.4-1 1.3-1.3 1.6-.2.2-.5.3-.8.1-.4-.2-1.7-.6-3.2-2-1.2-1.1-2-2.4-2.2-2.8-.2-.4 0-.6.2-.8.2-.2.4-.4.5-.7.2-.2.2-.4.4-.6.1-.3 0-.5 0-.7-.1-.2-.9-2.1-1.2-2.9-.3-.7-.6-.6-.9-.7h-.7c-.2 0-.6.1-1 .5-.3.4-1.3 1.3-1.3 3.1s1.3 3.6 1.5 3.9c.2.2 2.6 4 6.4 5.6.9.4 1.6.6 2.1.8.9.3 1.7.2 2.3.1.7-.1 2.1-.9 2.4-1.7.3-.8.3-1.5.2-1.7-.1-.1-.3-.2-.7-.3z"/></svg>
          <span>WhatsApp</span>
        </a>
        <a href={`mailto:${site.contact.email}`} class="mt-3 flex items-center gap-2 text-sm transition-opacity hover:opacity-70" style="color:rgba(241,242,238,0.75)">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 6.5 8.5 6 8.5-6"/></svg>
          <span>{site.contact.email}</span>
        </a>
        <p class="mt-3 flex items-start gap-2 text-sm" style="color:rgba(241,242,238,0.6)">
          <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.6" style="flex:none;margin-top:1px"><path d="M12 21s7-6.3 7-11a7 7 0 1 0-14 0c0 4.7 7 11 7 11Z"/><circle cx="12" cy="10" r="2.5"/></svg>
          <span style="max-width:32ch;line-height:1.5">{site.contact.address.display}</span>
        </p>
      </div>
      <div>
        <p class="text-[0.72rem] tracking-[0.22em] uppercase font-semibold mb-4" style="color:rgba(241,242,238,0.5)">Brand</p>
        <ul class="space-y-3 text-sm">
          {activeBrands.map((b) => (
            <li>
              <a href={b.href} class="group inline-flex flex-col">
                <span class="font-display text-lg group-hover:opacity-70 transition-opacity" style="letter-spacing:0.02em; color:#f1f2ee">{b.wordmark}</span>
                <span class="text-[0.66rem] tracking-[0.2em] uppercase mt-0.5" style="color:rgba(241,242,238,0.4)">{typeof b.positioning === 'string' ? b.positioning : b.positioning.value}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
      <div>
        <p class="text-[0.72rem] tracking-[0.22em] uppercase font-semibold mb-4" style="color:rgba(241,242,238,0.5)">Partnership</p>
        <a href={site.whatsapp.href} target="_blank" rel="noopener noreferrer" class="text-sm transition-opacity hover:opacity-70" style="color:rgba(241,242,238,0.75)">Become a partner →</a>
      </div>
    </div>

    <div class="mt-16 mb-6" style="height:1px; background:rgba(215,230,63,0.25)"></div>
    <p class="text-xs" style="color:rgba(241,242,238,0.4)">© 2026 {site.legalName.value} All rights reserved.</p>
  </div>
</footer>
