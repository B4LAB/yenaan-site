---
import site from '../content/en/site.json';
---
<a
  href={site.whatsapp.href}
  target="_blank"
  rel="noopener noreferrer"
  aria-label="Chat with YENAAN on WhatsApp"
  class="wa-fab"
>
  <svg viewBox="0 0 32 32" width="19" height="19" aria-hidden="true" fill="currentColor" style="color:var(--color-citron,#c7d62f)">
    <path d="M16 .6C7.5.6.6 7.5.6 16c0 2.8.7 5.4 2.1 7.8L.5 31.5l7.9-2.1c2.3 1.2 4.8 1.9 7.6 1.9h.1c8.5 0 15.4-6.9 15.4-15.4C31.5 7.5 24.6.6 16 .6zm0 28.2h-.1c-2.4 0-4.8-.7-6.9-1.9l-.5-.3-4.7 1.2 1.3-4.6-.3-.5C3.4 20.5 2.7 18.3 2.7 16 2.7 8.7 8.7 2.7 16 2.7c3.6 0 6.9 1.4 9.4 3.9 2.5 2.5 3.9 5.9 3.9 9.4 0 7.3-6 13.3-13.3 13.3zm7.3-9.9c-.4-.2-2.4-1.2-2.7-1.3-.4-.1-.6-.2-.9.2-.3.4-1 1.3-1.3 1.6-.2.2-.5.3-.8.1-.4-.2-1.7-.6-3.2-2-1.2-1.1-2-2.4-2.2-2.8-.2-.4 0-.6.2-.8.2-.2.4-.4.5-.7.2-.2.2-.4.4-.6.1-.3 0-.5 0-.7-.1-.2-.9-2.1-1.2-2.9-.3-.7-.6-.6-.9-.7h-.7c-.2 0-.6.1-1 .5-.3.4-1.3 1.3-1.3 3.1s1.3 3.6 1.5 3.9c.2.2 2.6 4 6.4 5.6.9.4 1.6.6 2.1.8.9.3 1.7.2 2.3.1.7-.1 2.1-.9 2.4-1.7.3-.8.3-1.5.2-1.7-.1-.1-.3-.2-.7-.3z"/>
  </svg>
  <span>WhatsApp</span>
</a>
<style>
  .wa-fab{
    position:fixed; right:22px; bottom:22px; z-index:60;
    display:inline-flex; align-items:center; gap:9px;
    padding:12px 18px 12px 15px; border-radius:9999px;
    background:var(--color-charcoal, #171817);
    color:var(--color-canvas, #f4f3ee);
    border:1px solid rgba(244,243,238,0.15);
    box-shadow:0 8px 24px rgba(23,24,23,0.22);
    transition:transform .25s ease, box-shadow .25s ease;
    text-decoration:none;
  }
  .wa-fab span{ font-size:0.72rem; letter-spacing:0.18em; text-transform:uppercase; font-weight:600; }
  .wa-fab:hover{ transform:translateY(-2px); box-shadow:0 12px 30px rgba(23,24,23,0.30); }
  @media (max-width:640px){
    .wa-fab{ right:16px; bottom:16px; padding:0; width:56px; height:56px; justify-content:center; gap:0; }
    .wa-fab span{ display:none; }
    .wa-fab svg{ width:26px; height:26px; }
  }
</style>
