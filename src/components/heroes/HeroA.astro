---
import home from '../../content/en/home.json';
const lines = (s) => s.split('\n');
---
<section class="relative">
  <div class="mx-auto max-w-6xl px-6 lg:px-10 pt-24 pb-20 md:pt-32 md:pb-28 text-center">
    <p class="eyebrow mb-7">{home.hero.eyebrow}</p>
    <h1 class="font-display text-4xl sm:text-5xl md:text-[4.2rem] leading-[1.08] text-ink font-medium">
      {lines(home.hero.title).map((l) => (<span class="block">{l}</span>))}
    </h1>
    <div class="rule-gold w-16 mx-auto my-9"></div>
    <p class="mx-auto max-w-xl text-base md:text-lg text-ink-soft leading-relaxed">{home.hero.subtitle.value}</p>
    <a href="#brands" class="inline-block mt-10 text-[0.74rem] tracking-[0.22em] uppercase border border-ink/40 px-7 py-3 hover:border-amber hover:text-amber transition-colors">Explore the brands</a>
  </div>
</section>
